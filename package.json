{
  "name": "sport-prodavnica-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:admin",
    "dev:web": "npm --workspace=apps/web run dev",
    "dev:admin": "npm --workspace=apps/admin run dev",
    "build": "npm run build --workspace=apps/web --workspace=apps/admin",
    "start": "npm --workspace=apps/web run start",
    "lint": "npm --workspace=apps/web run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
